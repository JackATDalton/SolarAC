    "\n",
    "print(f\"Baseline IRR at 5% AC: {project_irr(curtailment_at_pen(0.05))*100:.2f}%\")\n",
    "print(f\"IRR at 30% AC: {project_irr(curtailment_at_pen(0.30))*100:.2f}%\")\n",
    "print(f\"IRR at 60% AC: {project_irr(curtailment_at_pen(0.60))*100:.2f}%\")"
   ]
